@page
@model Preventivatore.WebApp.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Registrati";
}

<div class="container mt-5" style="max-width:400px;">
    <h2>@ViewData["Title"]</h2>
    <form method="post">
        <partial name="_ValidationScriptsPartial" />
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" placeholder="Email" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label"></label>
            <input asp-for="Input.Password" type="password" class="form-control" placeholder="Password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.ConfirmPassword" class="form-label"></label>
            <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Conferma Password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        <input type="hidden" asp-for="ReturnUrl" />

        <button type="submit" class="btn btn-primary w-100">Registrati</button>

        <div class="text-center mt-2">
            <a asp-page="./Login">Hai già un account? Accedi</a>
        </div>
    </form>
</div>
