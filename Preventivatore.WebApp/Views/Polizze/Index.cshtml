@model IEnumerable<Preventivatore.WebApp.ViewModels.PolizzaGridViewModel>

@{
    ViewData["Title"] = "Elenco Coperture professionali";
}

<h1 class="mb-3">@ViewData["Title"]</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">
        Nuova Copertura professionale
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info shadow-sm">
        Nessuna Copertura professionale presente.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle shadow-sm">
            <thead class="table-light">
                <tr>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Importo Admin</th>
                    <th>% Admin</th>
                    <th style="width:220px">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Nome</td>
                        <td>@p.Categoria</td>
                        <td>@p.ImportoAdmin.ToString("0.00") €</td>
                        <td>@p.PercentualeAdmin.ToString("0.##") %</td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-action="Details"
                                   asp-route-id="@p.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Dettagli
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@p.Id"
                                   class="btn btn-sm btn-outline-warning">
                                    Modifica
                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@p.Id"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Sei sicuro di voler eliminare questa Copertura professionale?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger">
                                        Elimina
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}