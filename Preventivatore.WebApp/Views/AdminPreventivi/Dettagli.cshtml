@model Preventivatore.WebApp.ViewModels.AdminPreventivoViewModel

@{
    ViewData["Title"] = "Dettagli preventivo (Admin)";

    var badgeClass = Model.Stato switch
    {
        "Confermato" => "bg-success",
        "Rifiutato" => "bg-danger",
        _ => "bg-secondary"
    };
}

<h1 class="mb-3">Dettagli preventivo</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="card-title mb-3">Riepilogo preventivo</h5>

        <dl class="row mb-0">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Username</dt>
            <dd class="col-sm-9">@Model.UserName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">UserId</dt>
            <dd class="col-sm-9 text-break-anywhere">@Model.UserId</dd>

            <dt class="col-sm-3">Sottocategoria</dt>
            <dd class="col-sm-9">@Model.SubCategoriaNome (@Model.SubCategoriaId)</dd>

            <dt class="col-sm-3">Riga</dt>
            <dd class="col-sm-9">@Model.RowKey</dd>

            <dt class="col-sm-3">Colonna</dt>
            <dd class="col-sm-9">@Model.ColKey</dd>

            <dt class="col-sm-3">Valore</dt>
            <dd class="col-sm-9">@Model.Value</dd>

            <dt class="col-sm-3">Data</dt>
            <dd class="col-sm-9">@Model.DataCreazione.ToString("dd/MM/yyyy HH:mm:ss")</dd>

            <dt class="col-sm-3">Stato</dt>
            <dd class="col-sm-9">
                <span class="badge @badgeClass">@Model.Stato</span>
            </dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-secondary" asp-action="Index">Torna alla lista</a>
</div>