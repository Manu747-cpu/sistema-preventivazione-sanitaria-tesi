@model Preventivatore.Core.Entities.MacroCategoriaPolizza

@{
    ViewData["Title"] = "Modifica Categoria professionale";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Descrizione" class="form-label"></label>
        <textarea asp-for="Descrizione" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Descrizione" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Immagine corrente</label><br />
        @if (!string.IsNullOrEmpty(Model.UrlImmagine))
        {
            <img src="@Model.UrlImmagine" alt="@Model.Nome" style="height:75px;" />
        }
        else
        {
            <span class="text-muted">— nessuna immagine —</span>
        }
    </div>

    <div class="mb-3">
        <label for="ImmagineFile" class="form-label">Nuova immagine (opzionale)</label>
        <!-- Non usiamo asp-for, ma name="ImmagineFile" -->
        <input id="ImmagineFile" name="ImmagineFile" type="file"
               class="form-control" accept=".jpg,.jpeg,.png" />
        <span class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">
        <i class="bi bi-save"></i> Aggiorna
    </button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Annulla</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
