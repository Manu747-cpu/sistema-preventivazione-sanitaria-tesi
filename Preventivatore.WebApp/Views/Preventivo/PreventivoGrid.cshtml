@model Preventivatore.WebApp.ViewModels.PreventivoGridViewModel

<div class="container my-4">
    <!-- Massimali di copertura -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Massimali di copertura</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:200px;">Fatturato</th>
                        @foreach (var col in Model.CoverageColumns)
                        {
                            <th>@col</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.CoverageRows)
                    {
                        <tr>
                            <td>@row.Label</td>
                            @foreach (var val in row.Values)
                            {
                                <td>@val</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Franchigia -->
    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Franchigia</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:200px;"></th>
                        @foreach (var col in Model.CoverageColumns)
                        {
                            <th>@col</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.DeductibleRows)
                    {
                        <tr class="fw-bold text-primary">
                            <td>@row.Label</td>
                            @foreach (var val in row.Values)
                            {
                                <td>@val</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
