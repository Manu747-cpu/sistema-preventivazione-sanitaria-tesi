@* Views/Home/Index.cshtml *@
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container my-5">

    <div class="row mb-4">
        <div class="col text-center">
            <h2 class="fw-semibold">Tabelle principali</h2>
            <p class="text-muted mb-0">MVP tesi: gestione Macrocategorie, Polizze e Preventivi.</p>
        </div>
    </div>

    <div class="row g-4 justify-content-center">

        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="MacroCategorie" asp-action="Index"
               class="card-product d-flex flex-column align-items-center justify-content-center text-center">
                <i class="bi bi-grid-3x3-gap fs-1"></i>
                <span>Macrocategorie</span>
            </a>
        </div>

        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="Polizze" asp-action="Index"
               class="card-product d-flex flex-column align-items-center justify-content-center text-center">
                <i class="bi bi-journal-text fs-1"></i>
                <span>Polizze</span>
            </a>
        </div>

        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="AdminPreventivi" asp-action="Index"
               class="card-product d-flex flex-column align-items-center justify-content-center text-center">
                <i class="bi bi-clipboard-check fs-1"></i>
                <span>Preventivi</span>
            </a>
        </div>

    </div>

</div>